rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is an admin
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // bus_locations — drivers write their own doc; anyone (even unauthenticated) can read
    match /bus_locations/{driverId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == driverId;
    }

    // drivers — each driver owns their own document
    match /drivers/{driverId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == driverId;
      allow update: if isAuth() && (request.auth.uid == driverId || isAdmin());
      allow delete: if isAdmin();
    }

    // bus_stops — readable by all, writable by authenticated drivers
    match /bus_stops/{stopId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // admins — readable only by the admin themselves (for isAdmin() checks)
    match /admins/{adminId} {
      allow read: if isAuth() && request.auth.uid == adminId;
      allow write: if false;
    }

    // buses — readable by authenticated users, writable only by admins
    match /buses/{busId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // assignments — readable by authenticated users, writable only by admins
    match /assignments/{assignmentId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
