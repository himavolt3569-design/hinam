rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is an admin
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: caller owns the driver document at driverId
    function isOwner(driverId) {
      return isAuth() && request.auth.uid == driverId;
    }

    // Helper: driverId's driver profile has been approved by an admin
    function isApprovedDriver(driverId) {
      return get(/databases/$(database)/documents/drivers/$(driverId)).data.isApproved == true;
    }

    // bus_locations — drivers write their own doc once approved; anyone (even unauthenticated) can read
    match /bus_locations/{driverId} {
      allow read: if true;
      allow write: if isOwner(driverId) && isApprovedDriver(driverId);
    }

    // drivers — each driver owns their own document, but only an admin may change isApproved
    match /drivers/{driverId} {
      allow read: if isAuth();
      allow create: if isOwner(driverId) && request.resource.data.isApproved == false;
      allow update: if isAdmin()
        || (isOwner(driverId) && request.resource.data.isApproved == resource.data.isApproved);
      allow delete: if isAdmin();
    }

    // bus_stops — readable by all, writable by authenticated drivers
    match /bus_stops/{stopId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // admins — readable only by the admin themselves (for isAdmin() checks)
    match /admins/{adminId} {
      allow read: if isAuth() && request.auth.uid == adminId;
      allow write: if false;
    }

    // buses — readable by authenticated users, writable only by admins
    match /buses/{busId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // assignments — readable by authenticated users, writable only by admins
    match /assignments/{assignmentId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
