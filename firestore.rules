rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is an admin
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: caller owns the driver document at driverId
    function isOwner(driverId) {
      return isAuth() && request.auth.uid == driverId;
    }

    // Helper: driverId's driver profile has been approved by an admin
    function isApprovedDriver(driverId) {
      return get(/databases/$(database)/documents/drivers/$(driverId)).data.isApproved == true;
    }

    // Helper: driverId's ride driver profile has been approved by an admin
    function isApprovedRideDriver(driverId) {
      return get(/databases/$(database)/documents/ride_drivers/$(driverId)).data.verificationStatus == 'approved';
    }

    // bus_locations — drivers write their own doc once approved; anyone (even unauthenticated) can read
    match /bus_locations/{driverId} {
      allow read: if true;
      allow write: if isOwner(driverId) && isApprovedDriver(driverId);
    }

    // drivers — each driver owns their own document, but only an admin may change isApproved
    match /drivers/{driverId} {
      allow read: if isAuth();
      allow create: if isOwner(driverId) && request.resource.data.isApproved == false;
      allow update: if isAdmin()
        || (isOwner(driverId) && request.resource.data.isApproved == resource.data.isApproved);
      allow delete: if isAdmin();
    }

    // bus_stops — readable by all, writable by authenticated drivers
    match /bus_stops/{stopId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // admins — readable only by the admin themselves (for isAdmin() checks)
    match /admins/{adminId} {
      allow read: if isAuth() && request.auth.uid == adminId;
      allow write: if false;
    }

    // buses — readable by authenticated users, writable only by admins
    match /buses/{busId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // assignments — readable by authenticated users, writable only by admins
    match /assignments/{assignmentId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // fcm_tokens — each user owns their own push-notification token document
    match /fcm_tokens/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // ride_drivers — each ride driver owns their own document, but only an admin may change verificationStatus
    match /ride_drivers/{driverId} {
      allow read: if isAuth();
      allow create: if isOwner(driverId) && request.resource.data.verificationStatus == 'pending';
      allow update: if isAdmin()
        || (isOwner(driverId) && request.resource.data.verificationStatus == resource.data.verificationStatus);
      allow delete: if isAdmin();
    }

    // ride_passengers — unlike ride_drivers, readable only by the owner and admins: this document
    // carries emergency-contact phone numbers with no legitimate broad-read use case.
    // emergencyContacts is capped at 3 entries (mirrors RidePassengerModel.maxEmergencyContacts).
    match /ride_passengers/{passengerId} {
      allow read: if isOwner(passengerId) || isAdmin();
      allow create: if isOwner(passengerId)
        && request.resource.data.verificationStatus == 'pending'
        && request.resource.data.emergencyContacts.size() <= 3;
      allow update: if isAdmin()
        || (isOwner(passengerId)
            && request.resource.data.verificationStatus == resource.data.verificationStatus
            && request.resource.data.emergencyContacts.size() <= 3);
      allow delete: if isAdmin();
    }

    // ride_verifications — a subject (driver or passenger) submits their own requests.
    // History is immutable once created: resubmission creates a new document rather than
    // editing an old one. Only an admin may review (change status); nobody may delete.
    match /ride_verifications/{requestId} {
      allow read: if isOwner(resource.data.subjectId) || isAdmin();
      allow create: if isOwner(request.resource.data.subjectId)
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ride_locations — an approved ride driver broadcasts their own location.
    // Unlike bus_locations, this is NOT publicly readable: there is no passenger-matching
    // concept yet, so only the driver themselves and admins have any legitimate reason to read it.
    match /ride_locations/{driverId} {
      allow read: if isOwner(driverId) || isAdmin();
      allow write: if isOwner(driverId) && isApprovedRideDriver(driverId);
    }

    // rides — the Trip aggregate. A passenger creates their own request; driverId must be
    // null at creation since no matching exists yet. Not broadly readable: pickup/dropoff
    // reveal where a passenger is going — only the owning passenger, the matched driver
    // (once assigned), and admins may read.
    match /rides/{rideId} {
      allow read: if isOwner(resource.data.passengerId)
        || isOwner(resource.data.driverId)
        || isAdmin();

      allow create: if isOwner(request.resource.data.passengerId)
        && request.resource.data.driverId == null
        && request.resource.data.status == 'requested'
        && request.resource.data.agreedFare == null
        && request.resource.data.suggestedFare > 0;

      allow update: if
        // The owning passenger cancels their still-unmatched request.
        (isOwner(resource.data.passengerId)
          && resource.data.status == 'requested'
          && request.resource.data.status == 'cancelled'
          && request.resource.data.passengerId == resource.data.passengerId
          && request.resource.data.driverId == resource.data.driverId
          && request.resource.data.pickup == resource.data.pickup
          && request.resource.data.dropoff == resource.data.dropoff
          && request.resource.data.suggestedFare == resource.data.suggestedFare)
        ||
        // The driver named on a still-pending offer accepts it, matching the ride.
        // request.resource.data.acceptedOfferId names which offer; the referenced offer
        // document is independently checked for status == 'pending' and driverId ==
        // caller, and the agreedFare being set must equal that offer's own amount — a
        // driver cannot match themselves to a fare they were never actually offered.
        // This write must land before the paired offers/{offerId} update below, whose
        // rule cross-checks that this ride update already committed.
        (resource.data.status == 'requested'
          && resource.data.driverId == null
          && request.resource.data.status == 'matched'
          && isOwner(request.resource.data.driverId)
          && request.resource.data.passengerId == resource.data.passengerId
          && request.resource.data.pickup == resource.data.pickup
          && request.resource.data.dropoff == resource.data.dropoff
          && request.resource.data.agreedFare ==
            get(/databases/$(database)/documents/rides/$(rideId)/offers/$(request.resource.data.acceptedOfferId)).data.offerAmount
          && get(/databases/$(database)/documents/rides/$(rideId)/offers/$(request.resource.data.acceptedOfferId)).data.driverId == request.auth.uid
          && get(/databases/$(database)/documents/rides/$(rideId)/offers/$(request.resource.data.acceptedOfferId)).data.status == 'pending');

      allow delete: if false;

      // rides/{rideId}/offers — the app's first subcollection.
      match /offers/{offerId} {
        allow read: if isOwner(get(/databases/$(database)/documents/rides/$(rideId)).data.passengerId)
          || isOwner(resource.data.driverId)
          || isAdmin();

        allow create: if isOwner(get(/databases/$(database)/documents/rides/$(rideId)).data.passengerId)
          && request.resource.data.status == 'pending';

        allow update: if
          // The passenger's matching service expires a stale pending offer.
          (isOwner(get(/databases/$(database)/documents/rides/$(rideId)).data.passengerId)
            && resource.data.status == 'pending'
            && request.resource.data.status == 'expired'
            && request.resource.data.driverId == resource.data.driverId
            && request.resource.data.offerAmount == resource.data.offerAmount)
          ||
          // The offered driver declines.
          (isOwner(resource.data.driverId)
            && resource.data.status == 'pending'
            && request.resource.data.status == 'declined'
            && request.resource.data.driverId == resource.data.driverId
            && request.resource.data.offerAmount == resource.data.offerAmount)
          ||
          // The offered driver counters with a different fare, bounded to +/-20% of the
          // amount they were offered — never accepted directly here; see below.
          (isOwner(resource.data.driverId)
            && resource.data.status == 'pending'
            && request.resource.data.status == 'countered'
            && request.resource.data.driverId == resource.data.driverId
            && request.resource.data.offerAmount >= resource.data.offerAmount * 0.8
            && request.resource.data.offerAmount <= resource.data.offerAmount * 1.2)
          ||
          // The offered driver accepts. This must follow — never precede or stand
          // alone from — the matching rides/{rideId} update above: it cross-checks
          // the ride's already-committed state so an offer cannot be flipped to
          // accepted on its own, leaving a ride stranded with no driver assigned.
          (isOwner(resource.data.driverId)
            && resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && request.resource.data.driverId == resource.data.driverId
            && request.resource.data.offerAmount == resource.data.offerAmount
            && get(/databases/$(database)/documents/rides/$(rideId)).data.driverId == resource.data.driverId
            && get(/databases/$(database)/documents/rides/$(rideId)).data.acceptedOfferId == offerId
            && get(/databases/$(database)/documents/rides/$(rideId)).data.status == 'matched');

        allow delete: if false;
      }
    }
  }
}
